# Copy this file to .env.local and fill in values.
# NEVER commit .env.local — it is gitignored by Next.js by default.
# All Worker secrets (CLERK_SECRET_KEY, CLERK_WEBHOOK_SIGNING_SECRET)
# must be set via `wrangler secret put`, NOT in any file.

# Optional: SHA-256 hash of the superadmin email
SUPERADMIN_EMAIL_HASH=7c53d1000a6e300cd9c2a6886ed208f25b20cc8b9fb68165d3a95d1da09d171d

# Clerk publishable key — safe to expose; designed for frontend use
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Worker base URL (e.g., https://excise-worker.YOUR_SUBDOMAIN.workers.dev)
NEXT_PUBLIC_WORKER_URL=https://excise-worker.REPLACE_ME.workers.dev
